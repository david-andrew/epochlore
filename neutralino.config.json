{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "dev.epochlore.app",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/www/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": false
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "filesystem.*",
    "storage.*",
    "events.*",
    "window.*",
    "debug.log"
  ],
  "globalVariables": {},
  "modes": {
    "window": {
      "title": "Epochlore",
      "width": 1200,
      "height": 800,
      "minWidth": 640,
      "minHeight": 420,
      "center": true,
      "icon": "/www/icon.svg"
    }
  },
  "cli": {
    "binaryName": "epochlore",
    "resourcesPath": "/www/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/www/neutralino.js",
    "binaryVersion": "5.6.0",
    "clientVersion": "5.6.0"
  }
}
